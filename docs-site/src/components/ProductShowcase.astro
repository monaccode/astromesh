---
// Reusable "Mission Control" product showcase. Accent-driven so each Astromesh
// satellite (Cortex, Nexus, OS, Leia) gets a distinct hue while sharing one
// cohesive visual grammar. Versions are passed in as props (hardcoded by the
// caller) because these live in *separate* repos that the docs CI does not check
// out — reading them at build time would break the GitHub Pages build.
interface Line {
  t: string;
  k?: 'cmd' | 'comment' | 'key' | 'str' | 'plain';
}
interface Feature {
  icon: string; // raw inner SVG (paths)
  label: string;
  desc: string;
}
interface Cta {
  text: string;
  href: string;
}

interface Props {
  name: string;
  version: string;
  badge?: string;
  tagline: string;
  description: string;
  accent: string;
  accentDeep: string;
  panelTitle: string;
  lines: Line[];
  features: Feature[];
  terminal: string[];
  ctaPrimary: Cta;
  ctaSecondary: Cta;
}

const {
  name,
  version,
  badge = 'NEW',
  tagline,
  description,
  accent,
  accentDeep,
  panelTitle,
  lines,
  features,
  terminal,
  ctaPrimary,
  ctaSecondary,
} = Astro.props as Props;

const slug = name.toLowerCase();
---

<section class="ps-root" style={`--accent: ${accent}; --accent-deep: ${accentDeep};`} data-ps={slug}>
  <div class="ps-bg">
    <div class="ps-orb ps-orb-1"></div>
    <div class="ps-orb ps-orb-2"></div>
    <div class="ps-grid"></div>
  </div>

  <div class="ps-header">
    <div class="ps-badge-row">
      <span class="ps-badge-new">{badge}</span>
      <span class="ps-badge-ver">{slug}-v{version}</span>
    </div>
    <h2 class="ps-title">
      <span class="ps-title-thin">Astromesh</span>
      <span class="ps-title-bold">{name}</span>
    </h2>
    <p class="ps-subtitle">{tagline}</p>
    <p class="ps-desc">{description}</p>
  </div>

  <div class="ps-split">
    <div class="ps-panel">
      <div class="ps-chrome">
        <div class="ps-dots"><span></span><span></span><span></span></div>
        <span class="ps-filename">{panelTitle}</span>
      </div>
      <div class="ps-code">
        {lines.map((l, i) => (
          <div class="ps-line" style={`--li: ${i}`}>
            <span class="ps-ln">{String(i + 1).padStart(2, ' ')}</span>
            <span class={`ps-lc ps-${l.k ?? 'plain'}`}>{l.t}</span>
          </div>
        ))}
      </div>
      <div class="ps-panel-glow"></div>
    </div>

    <div class="ps-features">
      {features.map((f, i) => (
        <div class="ps-feat" style={`--fi: ${i}`}>
          <div class="ps-feat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={f.icon} />
            </svg>
          </div>
          <div class="ps-feat-text">
            <span class="ps-feat-label">{f.label}</span>
            <span class="ps-feat-desc">{f.desc}</span>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="ps-terminal">
    {terminal.map((cmd, i) => (
      <div class={`ps-term-row${i === terminal.length - 1 ? ' ps-term-run' : ''}`}>
        <span class="ps-term-prompt">$</span>
        <span class="ps-term-cmd">{cmd}</span>
      </div>
    ))}
  </div>

  <div class="ps-cta-row">
    <a class="ps-cta-primary" href={ctaPrimary.href}>
      {ctaPrimary.text}
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
      </svg>
    </a>
    <a class="ps-cta-secondary" href={ctaSecondary.href}>{ctaSecondary.text}</a>
  </div>
</section>

<style>
  .ps-root {
    position: relative;
    padding: 3rem 0 2rem;
    overflow: hidden;
  }

  .ps-bg { position: absolute; inset: 0; pointer-events: none; z-index: 0; }

  .ps-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0;
    animation: ps-fade 1.2s ease 0.3s forwards;
  }
  .ps-orb-1 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 14%, transparent) 0%, transparent 70%);
    top: -100px; right: -50px;
  }
  .ps-orb-2 {
    width: 300px; height: 300px;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent-deep) 10%, transparent) 0%, transparent 70%);
    bottom: -80px; left: -30px;
    animation-delay: 0.5s;
  }
  @keyframes ps-fade { to { opacity: 1; } }

  .ps-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(color-mix(in srgb, var(--accent) 4%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--accent) 4%, transparent) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 30%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 30%, transparent 100%);
  }

  .ps-header { position: relative; z-index: 1; text-align: center; margin-bottom: 2.5rem; }

  .ps-badge-row {
    display: flex; align-items: center; justify-content: center; gap: 0.5rem;
    margin-bottom: 1rem; opacity: 0;
    animation: ps-up 0.5s ease 0.1s forwards;
  }
  .ps-badge-new {
    font-family: var(--sl-font-mono);
    font-size: 0.6rem; font-weight: 700; letter-spacing: 0.15em;
    color: #0a0a0a;
    background: linear-gradient(135deg, var(--accent), var(--accent-deep));
    padding: 0.2em 0.55em; border-radius: 4px;
    animation: ps-badge-glow 2s ease-in-out infinite alternate;
  }
  @keyframes ps-badge-glow {
    from { box-shadow: 0 0 8px color-mix(in srgb, var(--accent) 30%, transparent); }
    to   { box-shadow: 0 0 20px color-mix(in srgb, var(--accent) 50%, transparent), 0 0 40px color-mix(in srgb, var(--accent) 15%, transparent); }
  }
  .ps-badge-ver {
    font-family: var(--sl-font-mono);
    font-size: 0.65rem; font-weight: 500;
    color: var(--accent); opacity: 0.75;
  }

  .ps-title {
    font-size: 2.6rem; line-height: 1.1; margin: 0 0 0.3rem;
    letter-spacing: -0.04em; opacity: 0;
    animation: ps-up 0.6s ease 0.2s forwards;
  }
  .ps-title-thin { font-weight: 300; color: var(--sl-color-gray-2); }
  .ps-title-bold {
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-deep) 55%, #00d4ff 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }

  .ps-subtitle {
    font-size: 0.85rem; font-weight: 500; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--accent);
    margin: 0 0 1rem; opacity: 0;
    animation: ps-up 0.6s ease 0.3s forwards;
  }
  .ps-desc {
    max-width: 540px; margin: 0 auto;
    font-size: 0.9rem; line-height: 1.65; color: var(--sl-color-gray-2);
    opacity: 0; animation: ps-up 0.6s ease 0.4s forwards;
  }
  @keyframes ps-up {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .ps-split {
    position: relative; z-index: 1;
    display: grid; grid-template-columns: 1.3fr 1fr; gap: 1.5rem;
    align-items: start; margin-bottom: 1.5rem; opacity: 0;
    animation: ps-up 0.7s ease 0.5s forwards;
  }

  .ps-panel {
    position: relative;
    border-radius: var(--am-radius, 0.625rem);
    border: 1px solid var(--am-border, rgba(255,255,255,0.08));
    background: rgba(10, 12, 18, 0.8);
    overflow: hidden;
  }
  .ps-chrome {
    display: flex; align-items: center; gap: 0.75rem;
    padding: 0.6rem 1rem;
    border-bottom: 1px solid var(--am-border, rgba(255,255,255,0.08));
    background: rgba(255, 255, 255, 0.02);
  }
  .ps-dots { display: flex; gap: 5px; }
  .ps-dots span { width: 8px; height: 8px; border-radius: 50%; background: rgba(255, 255, 255, 0.12); }
  .ps-dots span:first-child { background: #ff5f57; }
  .ps-dots span:nth-child(2) { background: #ffbd2e; }
  .ps-dots span:nth-child(3) { background: #28c840; }
  .ps-filename {
    font-family: var(--sl-font-mono); font-size: 0.7rem;
    color: var(--sl-color-gray-3); opacity: 0.7;
  }

  .ps-code {
    margin: 0; padding: 0.75rem 0; overflow-x: auto;
    font-family: var(--sl-font-mono); font-size: 0.78rem; line-height: 1;
  }
  .ps-line {
    display: flex; align-items: baseline; padding: 0.22em 1rem;
    opacity: 0; animation: ps-line-in 0.3s ease forwards;
    animation-delay: calc(0.6s + var(--li) * 0.06s);
    white-space: pre; transition: background 0.15s ease;
  }
  @keyframes ps-line-in {
    from { opacity: 0; transform: translateX(-8px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  .ps-line:hover { background: color-mix(in srgb, var(--accent) 4%, transparent); }
  .ps-ln {
    display: inline-block; width: 2ch; text-align: right;
    color: rgba(255, 255, 255, 0.18); margin-right: 1.5em;
    user-select: none; flex-shrink: 0; font-size: 0.7rem;
  }
  .ps-lc { flex: 1; min-width: 0; }
  .ps-cmd { color: #e2e8f0; }
  .ps-comment { color: rgba(255,255,255,0.32); font-style: italic; }
  .ps-key { color: color-mix(in srgb, var(--accent) 70%, white 30%); }
  .ps-str { color: #86efac; }
  .ps-plain { color: #cbd5e1; }

  .ps-panel-glow {
    position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
    width: 60%; height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0.4;
  }

  .ps-features { display: grid; grid-template-columns: 1fr; gap: 0.55rem; }
  .ps-feat {
    display: flex; align-items: center; gap: 0.85rem;
    padding: 0.7rem 0.9rem;
    border-radius: calc(var(--am-radius, 0.625rem) - 2px);
    border: 1px solid var(--am-border, rgba(255,255,255,0.08));
    background: var(--am-surface, rgba(255,255,255,0.03));
    opacity: 0; animation: ps-feat-in 0.4s ease forwards;
    animation-delay: calc(0.8s + var(--fi) * 0.08s);
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }
  .ps-feat:hover {
    border-color: color-mix(in srgb, var(--accent) 30%, transparent);
    transform: translateX(4px);
    box-shadow: -4px 0 16px color-mix(in srgb, var(--accent) 6%, transparent);
  }
  @keyframes ps-feat-in {
    from { opacity: 0; transform: translateX(12px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  .ps-feat-icon {
    width: 2.2rem; height: 2.2rem; display: grid; place-items: center;
    border-radius: 6px;
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    color: var(--accent); flex-shrink: 0;
  }
  .ps-feat-text { display: flex; flex-direction: column; gap: 0.1rem; }
  .ps-feat-label { font-size: 0.82rem; font-weight: 600; color: var(--sl-color-text); letter-spacing: -0.01em; }
  .ps-feat-desc { font-size: 0.72rem; color: var(--sl-color-gray-3); }

  .ps-terminal {
    position: relative; z-index: 1;
    border-radius: calc(var(--am-radius, 0.625rem) - 2px);
    border: 1px solid var(--am-border, rgba(255,255,255,0.08));
    background: rgba(10, 12, 18, 0.6);
    padding: 0.75rem 1rem; margin-bottom: 1.5rem;
    display: flex; flex-direction: column; gap: 0.35rem;
    opacity: 0; animation: ps-up 0.6s ease 1.4s forwards;
  }
  .ps-term-row {
    display: flex; align-items: center; gap: 0.6rem;
    font-family: var(--sl-font-mono); font-size: 0.73rem;
  }
  .ps-term-prompt { color: var(--accent); font-weight: 600; user-select: none; }
  .ps-term-cmd { color: var(--sl-color-gray-2); }
  .ps-term-run .ps-term-cmd {
    background: linear-gradient(90deg, var(--sl-color-gray-2) 0%, color-mix(in srgb, var(--accent) 70%, transparent) 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }

  .ps-cta-row {
    position: relative; z-index: 1;
    display: flex; align-items: center; justify-content: center; gap: 1rem;
    opacity: 0; animation: ps-up 0.6s ease 1.6s forwards;
  }
  .ps-cta-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.65rem 1.4rem; border-radius: 100px;
    font-size: 0.85rem; font-weight: 600; color: #06121a;
    background: linear-gradient(135deg, var(--accent), var(--accent-deep));
    text-decoration: none; transition: all 0.3s ease;
    box-shadow: 0 0 20px color-mix(in srgb, var(--accent) 20%, transparent);
  }
  .ps-cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 30px color-mix(in srgb, var(--accent) 35%, transparent), 0 4px 16px rgba(0, 0, 0, 0.3);
    text-decoration: none !important; gap: 0.7rem;
  }
  .ps-cta-secondary {
    display: inline-flex; align-items: center;
    padding: 0.65rem 1.4rem; border-radius: 100px;
    font-size: 0.85rem; font-weight: 500; color: var(--sl-color-gray-2);
    border: 1px solid var(--am-border, rgba(255,255,255,0.08));
    background: var(--am-surface, rgba(255,255,255,0.03));
    text-decoration: none; transition: all 0.25s ease;
  }
  .ps-cta-secondary:hover {
    border-color: color-mix(in srgb, var(--accent) 30%, transparent);
    color: var(--sl-color-text); text-decoration: none !important;
  }

  @media (max-width: 720px) {
    .ps-split { grid-template-columns: 1fr; }
    .ps-title { font-size: 2rem; }
    .ps-features { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .ps-features { grid-template-columns: 1fr; }
    .ps-cta-row { flex-direction: column; }
    .ps-terminal { overflow-x: auto; }
  }
</style>
