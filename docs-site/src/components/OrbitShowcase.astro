---
const features = [
  { icon: `<polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>`, label: 'One Command', desc: 'orbit apply' },
  { icon: `<path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>`, label: 'Cloud-Native', desc: 'Managed services' },
  { icon: `<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`, label: 'Multi-Cloud', desc: 'GCP first, then AWS & Azure' },
  { icon: `<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>`, label: 'Escape Hatch', desc: 'Eject to raw Terraform' },
  { icon: `<rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>`, label: 'Marketplace', desc: 'GCP Marketplace ready' },
  { icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`, label: 'Secure Defaults', desc: 'VPC, IAM, Auth Proxy' },
];

const resources = [
  { name: 'Cloud Run', color: '#4285f4', items: ['Runtime', 'Cloud API', 'Studio'] },
  { name: 'Cloud SQL', color: '#ea4335', items: ['PostgreSQL 16'] },
  { name: 'Memorystore', color: '#fbbc04', items: ['Redis'] },
  { name: 'Secret Manager', color: '#34a853', items: ['JWT', 'Provider Keys'] },
];
---

<section class="orbit-root">
  <div class="orbit-bg">
    <div class="orbit-orb orbit-orb-1"></div>
    <div class="orbit-orb orbit-orb-2"></div>
    <div class="orbit-grid-overlay"></div>
  </div>

  <div class="orbit-header">
    <div class="orbit-badge-row">
      <span class="orbit-badge-new">NEW</span>
      <span class="orbit-badge-ver">orbit-v0.1.0</span>
    </div>
    <h2 class="orbit-title">
      <span class="orbit-title-thin">Astromesh</span>
      <span class="orbit-title-bold">Orbit</span>
    </h2>
    <p class="orbit-subtitle">Deploy to Any Cloud</p>
    <p class="orbit-desc">
      One command to provision a production-ready Astromesh stack on GCP.
      Cloud-native managed services, declarative config, and an escape hatch to raw Terraform.
    </p>
  </div>

  <div class="orbit-split">
    <div class="orbit-code-panel">
      <div class="orbit-code-chrome">
        <div class="orbit-dots">
          <span></span><span></span><span></span>
        </div>
        <span class="orbit-code-filename">orbit.yaml</span>
      </div>
      <div class="orbit-code">
        <div class="orbit-line" style="--li: 0"><span class="orbit-ln"> 1</span><span class="orbit-lc orbit-kw">apiVersion:</span><span class="orbit-lc"> astromesh/v1</span></div>
        <div class="orbit-line" style="--li: 1"><span class="orbit-ln"> 2</span><span class="orbit-lc orbit-kw">kind:</span><span class="orbit-lc"> OrbitDeployment</span></div>
        <div class="orbit-line" style="--li: 2"><span class="orbit-ln"> 3</span><span class="orbit-lc orbit-kw">metadata:</span></div>
        <div class="orbit-line" style="--li: 3"><span class="orbit-ln"> 4</span><span class="orbit-lc orbit-arg">  name:</span><span class="orbit-lc orbit-str"> my-astromesh</span></div>
        <div class="orbit-line" style="--li: 4"><span class="orbit-ln"> 5</span><span class="orbit-lc orbit-arg">  environment:</span><span class="orbit-lc orbit-str"> production</span></div>
        <div class="orbit-line" style="--li: 5"><span class="orbit-ln"> 6</span><span class="orbit-lc orbit-kw">spec:</span></div>
        <div class="orbit-line" style="--li: 6"><span class="orbit-ln"> 7</span><span class="orbit-lc orbit-arg">  provider:</span></div>
        <div class="orbit-line" style="--li: 7"><span class="orbit-ln"> 8</span><span class="orbit-lc orbit-body">    name: gcp</span></div>
        <div class="orbit-line" style="--li: 8"><span class="orbit-ln"> 9</span><span class="orbit-lc orbit-body">    project: my-project-123</span></div>
        <div class="orbit-line" style="--li: 9"><span class="orbit-ln">10</span><span class="orbit-lc orbit-body">    region: us-central1</span></div>
      </div>
      <div class="orbit-code-glow"></div>
    </div>

    <div class="orbit-features">
      {features.map((f, i) => (
        <div class="orbit-feat" style={`--fi: ${i}`}>
          <div class="orbit-feat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={f.icon} />
            </svg>
          </div>
          <div class="orbit-feat-text">
            <span class="orbit-feat-label">{f.label}</span>
            <span class="orbit-feat-desc">{f.desc}</span>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="orbit-resources">
    <p class="orbit-resources-label">What gets provisioned:</p>
    <div class="orbit-resource-row">
      {resources.map((r) => (
        <div class="orbit-resource" style={`--rc: ${r.color}`}>
          <span class="orbit-resource-name">{r.name}</span>
          <span class="orbit-resource-items">{r.items.join(' / ')}</span>
        </div>
      ))}
    </div>
  </div>

  <div class="orbit-terminal">
    <div class="orbit-term-row">
      <span class="orbit-term-prompt">$</span>
      <span class="orbit-term-cmd">pip install astromesh-orbit[gcp]</span>
    </div>
    <div class="orbit-term-row orbit-term-run">
      <span class="orbit-term-prompt">$</span>
      <span class="orbit-term-cmd">astromeshctl orbit apply --preset starter</span>
    </div>
  </div>

  <div class="orbit-cta-row">
    <a class="orbit-cta-primary" href="/astromesh/orbit/quickstart/">
      Deploy with Orbit
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
      </svg>
    </a>
    <a class="orbit-cta-secondary" href="/astromesh/orbit/introduction/">
      Read the Docs
    </a>
  </div>
</section>

<style>
  .orbit-root {
    position: relative;
    padding: 3rem 0 2rem;
    overflow: hidden;
  }

  .orbit-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .orbit-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0;
    animation: orbit-fade 1.2s ease 0.3s forwards;
  }

  .orbit-orb-1 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.12) 0%, transparent 70%);
    top: -100px;
    right: -50px;
  }

  .orbit-orb-2 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(6, 182, 212, 0.08) 0%, transparent 70%);
    bottom: -80px;
    left: -30px;
    animation-delay: 0.5s;
  }

  @keyframes orbit-fade {
    to { opacity: 1; }
  }

  .orbit-grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(139, 92, 246, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(139, 92, 246, 0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 30%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 30%, transparent 100%);
  }

  .orbit-header {
    position: relative;
    z-index: 1;
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .orbit-badge-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    opacity: 0;
    animation: orbit-slide-up 0.5s ease 0.1s forwards;
  }

  .orbit-badge-new {
    font-family: var(--sl-font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #0a0a0a;
    background: linear-gradient(135deg, #8b5cf6, #6d28d9);
    padding: 0.2em 0.55em;
    border-radius: 4px;
    animation: orbit-badge-glow 2s ease-in-out infinite alternate;
  }

  @keyframes orbit-badge-glow {
    from { box-shadow: 0 0 8px rgba(139, 92, 246, 0.3); }
    to   { box-shadow: 0 0 20px rgba(139, 92, 246, 0.5), 0 0 40px rgba(139, 92, 246, 0.15); }
  }

  .orbit-badge-ver {
    font-family: var(--sl-font-mono);
    font-size: 0.65rem;
    font-weight: 500;
    color: #8b5cf6;
    opacity: 0.7;
  }

  .orbit-title {
    font-size: 2.6rem;
    line-height: 1.1;
    margin: 0 0 0.3rem;
    letter-spacing: -0.04em;
    opacity: 0;
    animation: orbit-slide-up 0.6s ease 0.2s forwards;
  }

  .orbit-title-thin {
    font-weight: 300;
    color: var(--sl-color-gray-2);
  }

  .orbit-title-bold {
    font-weight: 800;
    background: linear-gradient(135deg, #8b5cf6 0%, #6d28d9 50%, #00d4ff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .orbit-subtitle {
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #a78bfa;
    margin: 0 0 1rem;
    opacity: 0;
    animation: orbit-slide-up 0.6s ease 0.3s forwards;
  }

  .orbit-desc {
    max-width: 520px;
    margin: 0 auto;
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--sl-color-gray-2);
    opacity: 0;
    animation: orbit-slide-up 0.6s ease 0.4s forwards;
  }

  @keyframes orbit-slide-up {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .orbit-split {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 1.5rem;
    align-items: start;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: orbit-slide-up 0.7s ease 0.5s forwards;
  }

  .orbit-code-panel {
    position: relative;
    border-radius: var(--am-radius, 0.625rem);
    border: 1px solid var(--am-border, rgba(255,255,255,0.08));
    background: rgba(10, 12, 18, 0.8);
    overflow: hidden;
  }

  .orbit-code-chrome {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1rem;
    border-bottom: 1px solid var(--am-border, rgba(255,255,255,0.08));
    background: rgba(255, 255, 255, 0.02);
  }

  .orbit-dots {
    display: flex;
    gap: 5px;
  }

  .orbit-dots span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
  }

  .orbit-dots span:first-child { background: #ff5f57; }
  .orbit-dots span:nth-child(2) { background: #ffbd2e; }
  .orbit-dots span:nth-child(3) { background: #28c840; }

  .orbit-code-filename {
    font-family: var(--sl-font-mono);
    font-size: 0.7rem;
    color: var(--sl-color-gray-3);
    opacity: 0.6;
  }

  .orbit-code {
    margin: 0;
    padding: 0.75rem 0;
    overflow-x: auto;
    font-family: var(--sl-font-mono);
    font-size: 0.78rem;
    line-height: 1;
    background: transparent;
  }

  .orbit-line {
    display: flex;
    align-items: baseline;
    padding: 0.22em 1rem;
    opacity: 0;
    animation: orbit-line-in 0.3s ease forwards;
    animation-delay: calc(0.6s + var(--li) * 0.06s);
    white-space: pre;
    transition: background 0.15s ease;
  }

  @keyframes orbit-line-in {
    from { opacity: 0; transform: translateX(-8px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .orbit-ln {
    display: inline-block;
    width: 2ch;
    text-align: right;
    color: rgba(255, 255, 255, 0.18);
    margin-right: 1.5em;
    user-select: none;
    flex-shrink: 0;
    font-size: 0.7rem;
  }

  .orbit-lc {
    flex: 1;
    min-width: 0;
  }

  .orbit-lc.orbit-kw { color: #c4b5fd; }
  .orbit-lc.orbit-arg { color: #94a3b8; }
  .orbit-lc.orbit-str { color: #86efac; }
  .orbit-lc.orbit-body { color: #e2e8f0; }

  .orbit-line:hover {
    background: rgba(139, 92, 246, 0.04);
  }

  .orbit-code-glow {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 1px;
    background: linear-gradient(90deg, transparent, #8b5cf6, transparent);
    opacity: 0.4;
  }

  .orbit-features {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.55rem;
  }

  .orbit-feat {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.7rem 0.9rem;
    border-radius: calc(var(--am-radius, 0.625rem) - 2px);
    border: 1px solid var(--am-border, rgba(255,255,255,0.08));
    background: var(--am-surface, rgba(255,255,255,0.03));
    opacity: 0;
    animation: orbit-feat-in 0.4s ease forwards;
    animation-delay: calc(0.8s + var(--fi) * 0.08s);
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  .orbit-feat:hover {
    border-color: rgba(139, 92, 246, 0.3);
    transform: translateX(4px);
    box-shadow: -4px 0 16px rgba(139, 92, 246, 0.06);
  }

  @keyframes orbit-feat-in {
    from { opacity: 0; transform: translateX(12px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .orbit-feat-icon {
    width: 2.2rem;
    height: 2.2rem;
    display: grid;
    place-items: center;
    border-radius: 6px;
    background: rgba(139, 92, 246, 0.1);
    color: #8b5cf6;
    flex-shrink: 0;
  }

  .orbit-feat-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .orbit-feat-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--sl-color-text);
    letter-spacing: -0.01em;
  }

  .orbit-feat-desc {
    font-size: 0.72rem;
    color: var(--sl-color-gray-3);
  }

  .orbit-resources {
    position: relative;
    z-index: 1;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: orbit-slide-up 0.6s ease 1.2s forwards;
  }

  .orbit-resources-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--sl-color-gray-3);
    margin: 0 0 0.75rem;
    text-align: center;
  }

  .orbit-resource-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.65rem;
  }

  .orbit-resource {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.75rem 0.9rem;
    border-radius: calc(var(--am-radius, 0.625rem) - 2px);
    border: 1px solid var(--am-border, rgba(255,255,255,0.08));
    border-top: 2px solid var(--rc);
    background: var(--am-surface, rgba(255,255,255,0.03));
    text-align: center;
    transition: border-color 0.25s ease, transform 0.25s ease;
  }

  .orbit-resource:hover {
    transform: translateY(-2px);
    border-top-color: var(--rc);
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
  }

  .orbit-resource-name {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--sl-color-text);
  }

  .orbit-resource-items {
    font-size: 0.68rem;
    color: var(--sl-color-gray-3);
  }

  .orbit-terminal {
    position: relative;
    z-index: 1;
    border-radius: calc(var(--am-radius, 0.625rem) - 2px);
    border: 1px solid var(--am-border, rgba(255,255,255,0.08));
    background: rgba(10, 12, 18, 0.6);
    padding: 0.75rem 1rem;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    opacity: 0;
    animation: orbit-slide-up 0.6s ease 1.4s forwards;
  }

  .orbit-term-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--sl-font-mono);
    font-size: 0.73rem;
  }

  .orbit-term-prompt {
    color: #8b5cf6;
    font-weight: 600;
    user-select: none;
  }

  .orbit-term-cmd {
    color: var(--sl-color-gray-2);
  }

  .orbit-term-run .orbit-term-cmd {
    background: linear-gradient(90deg, var(--sl-color-gray-2) 0%, rgba(139, 92, 246, 0.7) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .orbit-cta-row {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    opacity: 0;
    animation: orbit-slide-up 0.6s ease 1.6s forwards;
  }

  .orbit-cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.4rem;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    color: #ffffff;
    background: linear-gradient(135deg, #8b5cf6, #6d28d9);
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 0 20px rgba(139, 92, 246, 0.2);
  }

  .orbit-cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 30px rgba(139, 92, 246, 0.35), 0 4px 16px rgba(0, 0, 0, 0.3);
    text-decoration: none !important;
    gap: 0.7rem;
  }

  .orbit-cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.4rem;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--sl-color-gray-2);
    border: 1px solid var(--am-border, rgba(255,255,255,0.08));
    background: var(--am-surface, rgba(255,255,255,0.03));
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .orbit-cta-secondary:hover {
    border-color: rgba(139, 92, 246, 0.3);
    color: var(--sl-color-text);
    text-decoration: none !important;
  }

  @media (max-width: 720px) {
    .orbit-split {
      grid-template-columns: 1fr;
    }

    .orbit-title {
      font-size: 2rem;
    }

    .orbit-features {
      grid-template-columns: repeat(2, 1fr);
    }

    .orbit-resource-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .orbit-features {
      grid-template-columns: 1fr;
    }

    .orbit-resource-row {
      grid-template-columns: 1fr;
    }

    .orbit-cta-row {
      flex-direction: column;
    }

    .orbit-terminal {
      overflow-x: auto;
    }
  }
</style>
