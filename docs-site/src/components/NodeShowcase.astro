---
const platforms = [
  {
    name: 'Debian / Ubuntu',
    icon: `<circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>`,
    color: '#e95420',
    cmd: 'sudo apt install ./astromesh_latest_amd64.deb',
  },
  {
    name: 'RHEL / Fedora',
    icon: `<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/>`,
    color: '#cc0000',
    cmd: 'sudo dnf install ./astromesh_latest_x86_64.rpm',
  },
  {
    name: 'macOS',
    icon: `<path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C6.5 2.8 5.4 3.1 5.4 3.1a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 9.5c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21"/>`,
    color: '#a2aaad',
    cmd: 'sudo ./install.sh',
  },
  {
    name: 'Windows',
    icon: `<rect x="3" y="3" width="8" height="8"/><rect x="13" y="3" width="8" height="8"/><rect x="3" y="13" width="8" height="8"/><rect x="13" y="13" width="8" height="8"/>`,
    color: '#0078d4',
    cmd: '.\\install.ps1',
  },
];

const features = [
  { icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`, label: 'System Service', desc: 'systemd, launchd, WinSvc' },
  { icon: `<polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>`, label: 'CLI Management', desc: 'astromeshctl' },
  { icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>`, label: '7 Profiles', desc: 'full, gateway, worker...' },
  { icon: `<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`, label: 'Cross-Platform', desc: 'Linux, macOS, Windows' },
  { icon: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`, label: 'Auto-Restart', desc: 'Restart on failure' },
  { icon: `<circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/>`, label: 'Health Checks', desc: 'doctor + watchdog' },
];
---

<section class="node-root">
  <div class="node-bg">
    <div class="node-orb node-orb-1"></div>
    <div class="node-orb node-orb-2"></div>
    <div class="node-grid-overlay"></div>
  </div>

  <div class="node-header">
    <div class="node-badge-row">
      <span class="node-badge-new">NEW</span>
      <span class="node-badge-ver">node-v0.18.0</span>
    </div>
    <h2 class="node-title">
      <span class="node-title-thin">Astromesh</span>
      <span class="node-title-bold">Node</span>
    </h2>
    <p class="node-subtitle">Deploy as a Native System Service</p>
    <p class="node-desc">
      Install Astromesh as a first-class OS service on Linux, macOS, and Windows.
      Platform packages, automatic restarts, CLI management, and 7 runtime profiles — no containers required.
    </p>
  </div>

  <div class="node-split">
    <!-- Platform cards -->
    <div class="node-platforms">
      <p class="node-platforms-label">Choose your platform:</p>
      {platforms.map((p, i) => (
        <div class="node-platform" style={`--pi: ${i}; --pc: ${p.color}`}>
          <div class="node-platform-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={p.icon} />
            </svg>
          </div>
          <div class="node-platform-text">
            <span class="node-platform-name">{p.name}</span>
            <code class="node-platform-cmd">{p.cmd}</code>
          </div>
        </div>
      ))}
    </div>

    <!-- Features grid -->
    <div class="node-features">
      {features.map((f, i) => (
        <div class="node-feat" style={`--fi: ${i}`}>
          <div class="node-feat-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={f.icon} />
            </svg>
          </div>
          <div class="node-feat-text">
            <span class="node-feat-label">{f.label}</span>
            <span class="node-feat-desc">{f.desc}</span>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="node-terminal">
    <div class="node-term-row">
      <span class="node-term-prompt">$</span>
      <span class="node-term-cmd">sudo astromeshctl init --profile full</span>
    </div>
    <div class="node-term-row node-term-run">
      <span class="node-term-prompt">$</span>
      <span class="node-term-cmd">astromeshctl status</span>
    </div>
    <div class="node-term-row node-term-output">
      <span class="node-term-output-text">● Running  v0.18.0  1 agent loaded  1 provider healthy</span>
    </div>
  </div>

  <div class="node-cta-row">
    <a class="node-cta-primary" href="/astromesh/node/quick-start/">
      Get Started with Node
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
      </svg>
    </a>
    <a class="node-cta-secondary" href="/astromesh/node/introduction/">
      Read the Docs
    </a>
  </div>
</section>

<style>
  /* ── Root ─────────────────────────────── */
  .node-root {
    position: relative;
    padding: 3rem 0 2rem;
    overflow: hidden;
  }

  /* ── Ambient BG ──────────────────────── */
  .node-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .node-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0;
    animation: node-fade 1.2s ease 0.3s forwards;
  }

  .node-orb-1 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(16, 185, 129, 0.12) 0%, transparent 70%);
    top: -100px;
    left: -50px;
  }

  .node-orb-2 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(5, 150, 105, 0.08) 0%, transparent 70%);
    bottom: -80px;
    right: -30px;
    animation-delay: 0.5s;
  }

  @keyframes node-fade {
    to { opacity: 1; }
  }

  .node-grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(16, 185, 129, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(16, 185, 129, 0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 30%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 30%, transparent 100%);
  }

  /* ── Header ──────────────────────────── */
  .node-header {
    position: relative;
    z-index: 1;
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .node-badge-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    opacity: 0;
    animation: node-slide-up 0.5s ease 0.1s forwards;
  }

  .node-badge-new {
    font-family: var(--sl-font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #0a0a0a;
    background: linear-gradient(135deg, #10b981, #059669);
    padding: 0.2em 0.55em;
    border-radius: 4px;
    animation: node-badge-glow 2s ease-in-out infinite alternate;
  }

  @keyframes node-badge-glow {
    from { box-shadow: 0 0 8px rgba(16, 185, 129, 0.3); }
    to   { box-shadow: 0 0 20px rgba(16, 185, 129, 0.5), 0 0 40px rgba(16, 185, 129, 0.15); }
  }

  .node-badge-ver {
    font-family: var(--sl-font-mono);
    font-size: 0.65rem;
    font-weight: 500;
    color: #10b981;
    opacity: 0.7;
  }

  .node-title {
    font-size: 2.6rem;
    line-height: 1.1;
    margin: 0 0 0.3rem;
    letter-spacing: -0.04em;
    opacity: 0;
    animation: node-slide-up 0.6s ease 0.2s forwards;
  }

  .node-title-thin {
    font-weight: 300;
    color: var(--sl-color-gray-2);
  }

  .node-title-bold {
    font-weight: 800;
    background: linear-gradient(135deg, #10b981 0%, #059669 50%, #00d4ff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .node-subtitle {
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #34d399;
    margin: 0 0 1rem;
    opacity: 0;
    animation: node-slide-up 0.6s ease 0.3s forwards;
  }

  .node-desc {
    max-width: 520px;
    margin: 0 auto;
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--sl-color-gray-2);
    opacity: 0;
    animation: node-slide-up 0.6s ease 0.4s forwards;
  }

  @keyframes node-slide-up {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Split layout ────────────────────── */
  .node-split {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 1.5rem;
    align-items: start;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: node-slide-up 0.7s ease 0.5s forwards;
  }

  /* ── Platform cards ──────────────────── */
  .node-platforms {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .node-platforms-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--sl-color-gray-3);
    margin: 0 0 0.5rem;
  }

  .node-platform {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.65rem 0.9rem;
    border-radius: calc(var(--am-radius, 0.625rem) - 2px);
    border: 1px solid var(--am-border, rgba(255,255,255,0.08));
    border-left: 2px solid var(--pc);
    background: var(--am-surface, rgba(255,255,255,0.03));
    opacity: 0;
    animation: node-platform-in 0.4s ease forwards;
    animation-delay: calc(0.6s + var(--pi) * 0.1s);
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  .node-platform:hover {
    border-left-color: var(--pc);
    border-color: rgba(16, 185, 129, 0.2);
    transform: translateX(4px);
    box-shadow: -4px 0 16px rgba(16, 185, 129, 0.06);
  }

  @keyframes node-platform-in {
    from { opacity: 0; transform: translateX(-12px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .node-platform-icon {
    width: 2rem;
    height: 2rem;
    display: grid;
    place-items: center;
    border-radius: 6px;
    background: color-mix(in srgb, var(--pc) 12%, transparent);
    color: var(--pc);
    flex-shrink: 0;
  }

  .node-platform-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .node-platform-name {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--sl-color-text);
  }

  .node-platform-cmd {
    font-family: var(--sl-font-mono);
    font-size: 0.68rem;
    color: var(--sl-color-gray-3);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Features grid ───────────────────── */
  .node-features {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.55rem;
  }

  .node-feat {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.7rem 0.9rem;
    border-radius: calc(var(--am-radius, 0.625rem) - 2px);
    border: 1px solid var(--am-border, rgba(255,255,255,0.08));
    background: var(--am-surface, rgba(255,255,255,0.03));
    opacity: 0;
    animation: node-feat-in 0.4s ease forwards;
    animation-delay: calc(0.8s + var(--fi) * 0.08s);
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  .node-feat:hover {
    border-color: rgba(16, 185, 129, 0.3);
    transform: translateX(4px);
    box-shadow: -4px 0 16px rgba(16, 185, 129, 0.06);
  }

  @keyframes node-feat-in {
    from { opacity: 0; transform: translateX(12px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .node-feat-icon {
    width: 2.2rem;
    height: 2.2rem;
    display: grid;
    place-items: center;
    border-radius: 6px;
    background: rgba(16, 185, 129, 0.1);
    color: #10b981;
    flex-shrink: 0;
  }

  .node-feat-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .node-feat-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--sl-color-text);
    letter-spacing: -0.01em;
  }

  .node-feat-desc {
    font-size: 0.72rem;
    color: var(--sl-color-gray-3);
  }

  /* ── Terminal ────────────────────────── */
  .node-terminal {
    position: relative;
    z-index: 1;
    border-radius: calc(var(--am-radius, 0.625rem) - 2px);
    border: 1px solid var(--am-border, rgba(255,255,255,0.08));
    background: rgba(10, 12, 18, 0.6);
    padding: 0.75rem 1rem;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    opacity: 0;
    animation: node-slide-up 0.6s ease 1.4s forwards;
  }

  .node-term-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--sl-font-mono);
    font-size: 0.73rem;
  }

  .node-term-prompt {
    color: #10b981;
    font-weight: 600;
    user-select: none;
  }

  .node-term-cmd {
    color: var(--sl-color-gray-2);
  }

  .node-term-run .node-term-cmd {
    background: linear-gradient(90deg, var(--sl-color-gray-2) 0%, rgba(16, 185, 129, 0.7) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .node-term-output {
    padding-left: 0.6rem;
  }

  .node-term-output-text {
    font-family: var(--sl-font-mono);
    font-size: 0.7rem;
    color: #10b981;
    opacity: 0.8;
  }

  /* ── CTAs ─────────────────────────────── */
  .node-cta-row {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    opacity: 0;
    animation: node-slide-up 0.6s ease 1.6s forwards;
  }

  .node-cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.4rem;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    color: #0a0a0a;
    background: linear-gradient(135deg, #10b981, #059669);
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 0 20px rgba(16, 185, 129, 0.2);
  }

  .node-cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 30px rgba(16, 185, 129, 0.35), 0 4px 16px rgba(0, 0, 0, 0.3);
    text-decoration: none !important;
    gap: 0.7rem;
  }

  .node-cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.4rem;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--sl-color-gray-2);
    border: 1px solid var(--am-border, rgba(255,255,255,0.08));
    background: var(--am-surface, rgba(255,255,255,0.03));
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .node-cta-secondary:hover {
    border-color: rgba(16, 185, 129, 0.3);
    color: var(--sl-color-text);
    text-decoration: none !important;
  }

  /* ── Responsive ──────────────────────── */
  @media (max-width: 720px) {
    .node-split {
      grid-template-columns: 1fr;
    }

    .node-title {
      font-size: 2rem;
    }

    .node-features {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .node-features {
      grid-template-columns: 1fr;
    }

    .node-cta-row {
      flex-direction: column;
    }

    .node-terminal {
      overflow-x: auto;
    }
  }
</style>
