---
const steps = [
  {
    name: "Query",
    description: "User sends a query to the agent via REST API or WebSocket",
    link: "/astromesh/reference/api-endpoints/",
    svg: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
  },
  {
    name: "Input Guardrails",
    description: "PII detection, max length check, topic filtering on input",
    link: "/astromesh/configuration/agent-yaml/#guardrails",
    svg: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  },
  {
    name: "Prompt Engine",
    description: "Jinja2 renders the system prompt with memory context and variables",
    link: "/astromesh/configuration/agent-yaml/#prompts",
    svg: `<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/>`,
  },
  {
    name: "Model Router",
    description: "Routes to the best provider using cost, latency, or quality strategy",
    link: "/astromesh/reference/core/model-router/",
    svg: `<polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/>`,
  },
  {
    name: "Tool Calls",
    description: "Executes tools (internal, MCP, webhook, RAG) as directed by the LLM",
    link: "/astromesh/reference/core/tool-registry/",
    svg: `<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>`,
  },
  {
    name: "Output Guardrails",
    description: "Content filter, cost limit, PII redaction on output",
    link: "/astromesh/configuration/agent-yaml/#guardrails",
    svg: `<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>`,
  },
  {
    name: "Response",
    description: "Final response returned to the caller and persisted to memory",
    link: "/astromesh/reference/core/memory-manager/",
    svg: `<polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>`,
  },
];
---

<div class="pipeline-wrap">
  <div class="pipeline">
    {steps.map((step, i) => (
      <>
        <a href={step.link} class="step" style={`--i: ${i}`} title={`Learn more: ${step.name}`}>
          <div class="step-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={step.svg} />
            </svg>
          </div>
          <span class="step-num">{String(i + 1).padStart(2, "0")}</span>
          <span class="step-name">{step.name}</span>
          <div class="step-tooltip">
            <span class="step-tooltip-title">{step.name}</span>
            <p>{step.description}</p>
            <span class="step-tooltip-link">View docs &rarr;</span>
          </div>
        </a>
        {i < steps.length - 1 && (
          <div class="connector" style={`--i: ${i}`} aria-hidden="true">
            <svg width="32" height="12" viewBox="0 0 32 12" fill="none">
              <path d="M0 6h24" stroke="var(--sl-color-accent)" stroke-width="1.5" stroke-dasharray="4 3" opacity="0.5" />
              <path d="M22 2l4 4-4 4" stroke="var(--sl-color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
        )}
      </>
    ))}
  </div>

  <div class="pipeline-cta">
    <a href="/astromesh/architecture/agent-pipeline/" class="cta-btn">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
        fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
      </svg>
      Read full pipeline documentation
    </a>
  </div>
</div>

<style>
  .pipeline-wrap {
    padding: 2rem 0 0.5rem;
    overflow: visible;
  }

  .pipeline {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 1rem 0 2.5rem;
  }

  /* ── Step Card (now a link) ─────────── */
  .step {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    padding: 0.75rem 0.5rem 0.6rem;
    min-width: 0;
    flex: 1 1 0;
    max-width: 7.5rem;
    border-radius: var(--am-radius, 0.625rem);
    background: var(--am-surface, rgba(255,255,255,0.03));
    border: 1px solid var(--am-border, rgba(255,255,255,0.08));
    cursor: pointer;
    text-decoration: none !important;
    color: inherit;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;

    opacity: 0;
    transform: translateY(14px);
    animation: step-in 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(var(--i) * 0.1s);
  }

  .step:hover,
  .step:focus-visible {
    outline: none;
    border-color: var(--am-border-hover, rgba(0,212,255,0.4));
    box-shadow: 0 0 20px var(--am-glow, rgba(0,212,255,0.2)),
                inset 0 1px 0 rgba(255,255,255,0.06);
    transform: translateY(-3px);
    z-index: 10;
  }

  .step-icon {
    width: 2.5rem;
    height: 2.5rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: linear-gradient(135deg,
      var(--am-gradient-start, #00d4ff) 0%,
      var(--am-gradient-end, #06b6d4) 100%);
    color: white;
    box-shadow: 0 2px 10px var(--am-glow, rgba(0,212,255,0.35));
    flex-shrink: 0;
  }

  .step-num {
    font-family: var(--sl-font-mono, monospace);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--sl-color-accent);
    opacity: 0.7;
  }

  .step-name {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--sl-color-text);
    text-align: center;
    white-space: normal;
    letter-spacing: 0.01em;
    line-height: 1.3;
    word-break: break-word;
  }

  /* ── Tooltip ───────────────────────── */
  .step-tooltip {
    position: absolute;
    top: calc(100% + 0.75rem);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    width: max-content;
    max-width: 15rem;
    padding: 0.65rem 0.85rem;
    border-radius: var(--am-radius, 0.625rem);
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--am-border-hover, rgba(0,212,255,0.3));
    box-shadow: 0 4px 24px rgba(0,0,0,0.35),
                0 0 12px var(--am-glow, rgba(0,212,255,0.15));
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 30;
  }

  .step-tooltip::before {
    content: "";
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 6px solid transparent;
    border-bottom-color: var(--am-border-hover, rgba(0,212,255,0.3));
  }

  .step:hover .step-tooltip,
  .step:focus-visible .step-tooltip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .step-tooltip-title {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--sl-color-accent-high, #93c5fd);
    display: block;
    margin-bottom: 0.2rem;
  }

  .step-tooltip p {
    margin: 0;
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--sl-color-text);
    opacity: 0.85;
  }

  .step-tooltip-link {
    display: block;
    margin-top: 0.35rem;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--sl-color-accent);
  }

  /* ── Connector Arrow ───────────────── */
  .connector {
    flex-shrink: 1;
    display: grid;
    place-items: center;
    padding: 0;
    min-width: 1.25rem;
    opacity: 0;
    animation: fade-in 0.3s ease forwards;
    animation-delay: calc(var(--i) * 0.1s + 0.15s);
  }

  /* ── CTA Button ────────────────────── */
  .pipeline-cta {
    display: flex;
    justify-content: center;
    padding: 0.5rem 0 1rem;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1.2rem;
    border-radius: 2rem;
    background: var(--am-surface, rgba(255,255,255,0.03));
    border: 1px solid var(--am-border, rgba(255,255,255,0.1));
    color: var(--sl-color-text) !important;
    font-size: 0.8rem;
    font-weight: 500;
    text-decoration: none !important;
    transition: border-color 0.25s, box-shadow 0.25s, background 0.25s;
  }

  .cta-btn:hover {
    border-color: var(--sl-color-accent);
    background: rgba(0,212,255,0.08);
    box-shadow: 0 0 16px var(--am-glow, rgba(0,212,255,0.2));
  }

  .cta-btn svg {
    opacity: 0.7;
    color: var(--sl-color-accent);
  }

  /* ── Animations ────────────────────── */
  @keyframes step-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fade-in {
    to { opacity: 1; }
  }

  /* ── Responsive: stack vertical ────── */
  @media (max-width: 800px) {
    .pipeline {
      flex-direction: column;
      gap: 0;
      min-width: auto;
      padding: 1rem 0;
    }

    .step {
      flex-direction: row;
      gap: 0.75rem;
      min-width: auto;
      width: 100%;
      max-width: 22rem;
      padding: 0.75rem 1rem;
    }

    .step-icon {
      width: 2.25rem;
      height: 2.25rem;
    }

    .step-name {
      flex: 1;
      text-align: left;
    }

    .step-num {
      order: 3;
    }

    .step-tooltip {
      display: none;
    }

    .connector {
      padding: 0.15rem 0;
    }

    .connector svg {
      transform: rotate(90deg);
      width: 20px;
      height: 10px;
    }
  }
</style>
