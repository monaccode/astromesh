---
import ProductShowcase from './ProductShowcase.astro';

// Version is hardcoded: astromesh-cortex is a separate repo the docs CI does not
// check out. Bump on release. Source: astromesh-cortex/package.json.
const version = '0.12.0';

const lines = [
  { t: '{', k: 'plain' },
  { t: '  "name": "support-agents",', k: 'key' },
  { t: '  "connections": {', k: 'key' },
  { t: '    "runtime": [{ "type": "local", "url": ":8000" }],', k: 'str' },
  { t: '    "nexus":   [{ "tenantId": "prod" }]', k: 'str' },
  { t: '  },', k: 'plain' },
  { t: '  "environments": { "dev": { "vars": {…} } }', k: 'key' },
  { t: '}', k: 'plain' },
];

const features = [
  { icon: `<rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`, label: 'Desktop IDE', desc: 'Electron 41 · React 19' },
  { icon: `<rect x="3" y="3" width="6" height="6" rx="1"/><rect x="15" y="15" width="6" height="6" rx="1"/><path d="M9 6h6a2 2 0 0 1 2 2v7"/>`, label: 'Visual Builder', desc: 'Drag-and-drop canvas' },
  { icon: `<rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>`, label: 'Local Runtime', desc: 'Managed venv on :8000' },
  { icon: `<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.79-.78.8-2.07.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>`, label: 'Deploy Anywhere', desc: 'Local · GCP · Nexus' },
  { icon: `<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>`, label: 'Channels', desc: 'WhatsApp setup wizard' },
  { icon: `<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>`, label: 'Dev Tunnel', desc: 'ngrok / cloudflared' },
];
---

<ProductShowcase
  name="Cortex"
  version={version}
  badge="NEW"
  tagline="Desktop IDE & Control Plane"
  description="A native desktop IDE for designing, testing, and shipping agents — with a managed local runtime, GCP provisioning via Orbit, and a Nexus cloud console in a single window."
  accent="#38bdf8"
  accentDeep="#0ea5e9"
  panelTitle=".cortex/workspace.json"
  lines={lines}
  features={features}
  terminal={["npm install", "npm run dev"]}
  ctaPrimary={{ text: 'Launch Cortex', href: '/astromesh/cortex/quickstart/' }}
  ctaSecondary={{ text: 'Read the Docs', href: '/astromesh/cortex/introduction/' }}
/>
