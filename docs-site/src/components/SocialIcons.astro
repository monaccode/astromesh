---
import config from 'virtual:starlight/user-config';
import fs from 'node:fs';
import path from 'node:path';

// Read versions from pyproject.toml files at build time
function readVersion(relativePath: string, fallback: string = '0.0.0'): string {
  try {
    const content = fs.readFileSync(
      path.resolve(import.meta.dirname, relativePath),
      'utf-8'
    );
    const match = content.match(/^version\s*=\s*"([^"]+)"/m);
    return match ? match[1] : fallback;
  } catch {
    return fallback;
  }
}

const versions = [
  {
    label: 'Core',
    version: readVersion('../../../pyproject.toml'),
    prefix: 'v',
    href: (v: string) => `https://github.com/monaccode/astromesh/releases/tag/v${v}`,
    accent: '#00d4ff',
  },
  {
    label: 'ADK',
    version: readVersion('../../../astromesh-adk/pyproject.toml'),
    prefix: 'adk-v',
    href: (v: string) => `https://github.com/monaccode/astromesh/releases/tag/adk-v${v}`,
    accent: '#8b5cf6',
  },
  {
    label: 'CLI',
    version: readVersion('../../../astromesh-cli/pyproject.toml'),
    prefix: 'cli-v',
    href: (v: string) => `https://github.com/monaccode/astromesh/releases/tag/cli-v${v}`,
    accent: '#f59e0b',
  },
  {
    label: 'Node',
    version: readVersion('../../../astromesh-node/pyproject.toml'),
    prefix: 'node-v',
    href: (v: string) => `https://github.com/monaccode/astromesh/releases/tag/node-v${v}`,
    accent: '#10b981',
  },
  {
    label: 'Orbit',
    version: readVersion('../../../astromesh-orbit/pyproject.toml'),
    prefix: 'orbit-v',
    href: (v: string) => `https://github.com/monaccode/astromesh/releases/tag/orbit-v${v}`,
    accent: '#ef4444',
  },
];

const links = config.social || [];

const iconSvg: Record<string, string> = {
  github: '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>',
};
---

<div class="version-group">
  {versions.map((v) => (
    <a
      href={v.href(v.version)}
      class="version-badge"
      title={`${v.label} ${v.prefix}${v.version}`}
      style={`--badge-accent: ${v.accent}`}
    >
      <span class="version-label">{v.label}</span>
      <span class="version-num">{v.prefix}{v.version}</span>
    </a>
  ))}
</div>

{links.map(({ label, href, icon }) => (
  <a {href} rel="me" class="sl-flex social-link">
    <span class="sr-only">{label}</span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <Fragment set:html={iconSvg[icon] || ''} />
    </svg>
  </a>
))}

<style>
  /* ── Version group ─────────────────────── */
  .version-group {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin-inline-end: 0.4rem;
  }

  .version-badge {
    display: inline-flex;
    align-items: center;
    gap: 0;
    text-decoration: none !important;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--badge-accent) 25%, transparent);
    transition: all 0.25s ease;
    line-height: 1;
  }

  .version-badge:hover {
    border-color: color-mix(in srgb, var(--badge-accent) 50%, transparent);
    box-shadow: 0 0 12px color-mix(in srgb, var(--badge-accent) 12%, transparent);
    transform: translateY(-1px);
  }

  .version-label {
    font-family: var(--sl-font);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--badge-accent);
    background: color-mix(in srgb, var(--badge-accent) 12%, transparent);
    padding: 0.25em 0.45em;
    white-space: nowrap;
  }

  .version-num {
    font-family: var(--sl-font-mono);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--sl-color-gray-2);
    padding: 0.25em 0.45em;
    background: color-mix(in srgb, var(--badge-accent) 4%, transparent);
    white-space: nowrap;
  }

  .version-badge:hover .version-num {
    color: var(--sl-color-text);
  }

  /* ── Social links ──────────────────────── */
  .social-link {
    color: var(--sl-color-text-accent);
    padding: 0.5em;
    margin: -0.5em;
  }
  .social-link:hover {
    opacity: 0.66;
  }

  /* ── Responsive ────────────────────────── */
  @media (max-width: 640px) {
    .version-group {
      gap: 0.2rem;
    }
    .version-label {
      display: none;
    }
    .version-num {
      border-radius: 4px;
    }
  }
</style>
