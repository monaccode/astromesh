---
import config from 'virtual:starlight/user-config';
import fs from 'node:fs';
import path from 'node:path';

// Read version from pyproject.toml at build time
let version = '0.0.0';
try {
  const pyproject = fs.readFileSync(
    path.resolve(import.meta.dirname, '../../../pyproject.toml'),
    'utf-8'
  );
  const match = pyproject.match(/^version\s*=\s*"([^"]+)"/m);
  if (match) version = match[1];
} catch {}

const links = config.social || [];

// Map Starlight icon names to SVG paths (only what we need)
const iconSvg: Record<string, string> = {
  github: '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>',
};
---

<a
  href={`https://github.com/monaccode/astromesh/releases/tag/v${version}`}
  class="version-badge sl-flex"
  title={`Astromesh v${version} — View release`}
>
  <span class="version-tag">v{version}</span>
</a>

{links.map(({ label, href, icon }) => (
  <a {href} rel="me" class="sl-flex social-link">
    <span class="sr-only">{label}</span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <Fragment set:html={iconSvg[icon] || ''} />
    </svg>
  </a>
))}

<style>
  .version-badge {
    display: inline-flex;
    align-items: center;
    text-decoration: none !important;
    margin-inline-end: 0.25rem;
  }

  .version-tag {
    font-family: var(--sl-font-mono);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--sl-color-accent);
    background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 25%, transparent);
    border-radius: 100px;
    padding: 0.2em 0.6em;
    line-height: 1;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .version-badge:hover .version-tag {
    background: color-mix(in srgb, var(--sl-color-accent) 18%, transparent);
    border-color: color-mix(in srgb, var(--sl-color-accent) 45%, transparent);
    box-shadow: 0 0 12px color-mix(in srgb, var(--sl-color-accent) 15%, transparent);
  }

  .social-link {
    color: var(--sl-color-text-accent);
    padding: 0.5em;
    margin: -0.5em;
  }
  .social-link:hover {
    opacity: 0.66;
  }
</style>
