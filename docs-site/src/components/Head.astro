---
// Override of Starlight's Head. Renders the default head, then bundles a client
// script that renders Mermaid diagrams (<pre class="mermaid">) with a theme
// derived from the site's "Mission Control" tokens (see custom.css): deep-navy
// nodes, cyan borders with a subtle glow, JetBrains Mono labels. Re-runs on
// Astro view transitions (astro:page-load).
import Default from '@astrojs/starlight/components/Head.astro';
---

<Default><slot /></Default>

<script>
	import mermaid from 'mermaid';

	const CYAN = '#00d4ff';

	mermaid.initialize({
		startOnLoad: false,
		securityLevel: 'strict',
		theme: 'base',
		fontFamily: "'JetBrains Mono', ui-monospace, monospace",
		themeVariables: {
			darkMode: true,
			background: 'transparent',
			fontFamily: "'JetBrains Mono', ui-monospace, monospace",
			fontSize: '14px',
			// Nodes
			primaryColor: '#0a1e2b',
			primaryBorderColor: CYAN,
			primaryTextColor: '#d6f2fb',
			secondaryColor: '#0d2233',
			secondaryBorderColor: '#3aa8c9',
			secondaryTextColor: '#cfeef8',
			tertiaryColor: 'rgba(0, 212, 255, 0.05)',
			tertiaryBorderColor: 'rgba(0, 212, 255, 0.25)',
			// Edges / text
			lineColor: '#4a90a4',
			textColor: '#c9e6f0',
			edgeLabelBackground: '#0a1420',
			// Notes
			noteBkgColor: '#0d2233',
			noteBorderColor: '#3aa8c9',
			noteTextColor: '#cfeef8',
			// Clusters / subgraphs
			clusterBkg: 'rgba(0, 212, 255, 0.04)',
			clusterBorder: 'rgba(0, 212, 255, 0.25)',
			// Sequence diagrams
			actorBkg: '#0a1e2b',
			actorBorder: CYAN,
			actorTextColor: '#d6f2fb',
			signalColor: '#c9e6f0',
			signalTextColor: '#c9e6f0',
			labelBoxBkgColor: '#0d2233',
			labelBoxBorderColor: '#3aa8c9',
			// State diagrams
			labelColor: '#d6f2fb',
		},
		// Signature: the cyan telemetry glow on node borders, matching the hero logo.
		themeCSS: `
			.node rect, .node polygon, .node circle, .node ellipse, .node path {
				filter: drop-shadow(0 0 5px rgba(0, 212, 255, 0.3));
			}
			.edgePath .path, .flowchart-link { stroke-width: 1.5px; }
			.cluster rect { rx: 10px; ry: 10px; }
			.actor { filter: drop-shadow(0 0 5px rgba(0, 212, 255, 0.25)); }
			/* Subgraph / composite-state titles: keep them legible on the dark panel. */
			.cluster-label text, .cluster-label .nodeLabel, .cluster-label span,
			.cluster-label foreignObject div, .statediagram-cluster .cluster-label text {
				fill: #7fd1e8 !important;
				color: #7fd1e8 !important;
				font-weight: 600;
				opacity: 1 !important;
			}
		`,
	});

	// ── Interactive controls: zoom (buttons + Ctrl/⌘-wheel), drag-to-pan,
	// double-click reset, and fullscreen — added to every rendered diagram.
	const ICON = {
		zoomIn:
			'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/><line x1="8" y1="11" x2="14" y2="11"/><line x1="11" y1="8" x2="11" y2="14"/></svg>',
		zoomOut:
			'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/><line x1="8" y1="11" x2="14" y2="11"/></svg>',
		reset:
			'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 2.6-6.3"/><polyline points="3 3 3 8 8 8"/></svg>',
		expand:
			'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>',
		compress:
			'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 14 10 14 10 20"/><polyline points="20 10 14 10 14 4"/><line x1="14" y1="10" x2="21" y2="3"/><line x1="3" y1="21" x2="10" y2="14"/></svg>',
	};

	function enhance(pre) {
		if (pre.dataset.zoomReady) return;
		const svg = pre.querySelector('svg');
		if (!svg) return;
		pre.dataset.zoomReady = '1';

		// Viewport clips the diagram while panning/zooming.
		const viewport = document.createElement('div');
		viewport.className = 'am-mmd-viewport';
		pre.insertBefore(viewport, svg);
		viewport.appendChild(svg);

		const MIN = 0.4;
		const MAX = 8;
		let scale = 1;
		let tx = 0;
		let ty = 0;
		const clamp = (v) => Math.min(MAX, Math.max(MIN, v));
		const apply = () => {
			svg.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`;
			pre.classList.toggle('am-mmd-zoomed', scale !== 1 || tx !== 0 || ty !== 0);
		};
		const zoomAt = (factor, cx, cy) => {
			const rect = viewport.getBoundingClientRect();
			const px = (cx ?? rect.left + rect.width / 2) - rect.left - rect.width / 2;
			const py = (cy ?? rect.top + rect.height / 2) - rect.top - rect.height / 2;
			const next = clamp(scale * factor);
			const ratio = next / scale;
			tx = px - (px - tx) * ratio;
			ty = py - (py - ty) * ratio;
			scale = next;
			apply();
		};
		const reset = () => {
			scale = 1;
			tx = 0;
			ty = 0;
			apply();
		};

		const bar = document.createElement('div');
		bar.className = 'am-mmd-controls';
		const mkBtn = (icon, title, onClick) => {
			const b = document.createElement('button');
			b.type = 'button';
			b.className = 'am-mmd-btn';
			b.title = title;
			b.setAttribute('aria-label', title);
			b.innerHTML = icon;
			b.addEventListener('click', (e) => {
				e.preventDefault();
				e.stopPropagation();
				onClick();
			});
			return b;
		};
		bar.appendChild(mkBtn(ICON.zoomOut, 'Alejar', () => zoomAt(1 / 1.25)));
		bar.appendChild(mkBtn(ICON.reset, 'Restablecer', reset));
		bar.appendChild(mkBtn(ICON.zoomIn, 'Acercar', () => zoomAt(1.25)));
		const fsBtn = mkBtn(ICON.expand, 'Pantalla completa', () => {
			if (document.fullscreenElement === pre) document.exitFullscreen?.();
			else pre.requestFullscreen?.();
		});
		bar.appendChild(fsBtn);
		pre.appendChild(bar);

		document.addEventListener('fullscreenchange', () => {
			const active = document.fullscreenElement === pre;
			fsBtn.innerHTML = active ? ICON.compress : ICON.expand;
			fsBtn.title = active ? 'Salir de pantalla completa' : 'Pantalla completa';
			fsBtn.setAttribute('aria-label', fsBtn.title);
		});

		// Ctrl/⌘ + wheel zooms; plain wheel keeps scrolling the page.
		viewport.addEventListener(
			'wheel',
			(e) => {
				if (!e.ctrlKey && !e.metaKey) return;
				e.preventDefault();
				zoomAt(e.deltaY < 0 ? 1.15 : 1 / 1.15, e.clientX, e.clientY);
			},
			{ passive: false },
		);

		// Drag to pan.
		let dragging = false;
		let ox = 0;
		let oy = 0;
		viewport.addEventListener('pointerdown', (e) => {
			dragging = true;
			ox = e.clientX - tx;
			oy = e.clientY - ty;
			viewport.setPointerCapture(e.pointerId);
			viewport.classList.add('am-grabbing');
		});
		viewport.addEventListener('pointermove', (e) => {
			if (!dragging) return;
			tx = e.clientX - ox;
			ty = e.clientY - oy;
			apply();
		});
		const endDrag = () => {
			dragging = false;
			viewport.classList.remove('am-grabbing');
		};
		viewport.addEventListener('pointerup', endDrag);
		viewport.addEventListener('pointercancel', endDrag);
		viewport.addEventListener('dblclick', (e) => {
			e.preventDefault();
			reset();
		});
	}

	async function render() {
		const nodes = document.querySelectorAll('pre.mermaid:not([data-processed])');
		if (nodes.length) {
			try {
				await mermaid.run({ nodes });
			} catch {
				/* a single bad diagram shouldn't block enhancing the rest */
			}
		}
		document.querySelectorAll('pre.mermaid[data-processed]').forEach(enhance);
	}

	// Module scripts are deferred, so the DOM is ready here → render immediately.
	// Also re-render after client-side navigations (Starlight view transitions).
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', render);
	} else {
		render();
	}
	document.addEventListener('astro:page-load', render);
</script>
