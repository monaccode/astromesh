---
const tabs = [
  {
    id: "standalone",
    label: "Standalone",
    icon: `<rect x="4" y="4" width="16" height="16" rx="2"/><line x1="9" y1="9" x2="15" y2="9"/><line x1="9" y1="13" x2="13" y2="13"/>`,
    code: `git clone https://github.com/monaccode/astromesh.git
cd astromesh
uv sync --extra all
astromeshctl init --dev
astromeshd --config ./config`,
  },
  {
    id: "os",
    label: "Astromesh Node",
    icon: `<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`,
    code: `# Download latest .deb from GitHub Releases
curl -LO https://github.com/monaccode/astromesh/releases/latest/download/astromesh_<VERSION>_amd64.deb

# Install and start
sudo apt install ./astromesh_<VERSION>_amd64.deb
sudo astromeshctl init
sudo systemctl enable --now astromeshd`,
  },
  {
    id: "docker",
    label: "Docker",
    icon: `<path d="M22 12s-3-3-5-3c-.5 0-1 .1-1.4.3-1.2-2.2-3.6-3.3-6.1-3.3-4.1 0-7.5 3.3-7.5 7.5 0 .7.1 1.3.2 2"/><rect x="2" y="16" width="4" height="3" rx=".5"/><rect x="7" y="16" width="4" height="3" rx=".5"/><rect x="12" y="16" width="4" height="3" rx=".5"/><rect x="7" y="12" width="4" height="3" rx=".5"/><rect x="12" y="12" width="4" height="3" rx=".5"/>`,
    code: `# Single node with Ollama
docker compose -f recipes/single-node.yml up -d
curl http://localhost:8000/v1/health`,
  },
  {
    id: "maia",
    label: "Maia Mesh",
    icon: `<circle cx="12" cy="5" r="2"/><circle cx="5" cy="19" r="2"/><circle cx="19" cy="19" r="2"/><line x1="12" y1="7" x2="5" y2="17"/><line x1="12" y1="7" x2="19" y2="17"/><line x1="7" y1="19" x2="17" y2="19"/>`,
    code: `# 3-node mesh: gateway + worker + inference
docker compose -f recipes/mesh-3node.yml up -d
curl http://localhost:8000/v1/mesh/state`,
  },
  {
    id: "maia-gpu",
    label: "Maia + GPU",
    icon: `<rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 9h6v6H9z"/><line x1="9" y1="2" x2="9" y2="4"/><line x1="15" y1="2" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="22"/><line x1="15" y1="20" x2="15" y2="22"/><line x1="2" y1="9" x2="4" y2="9"/><line x1="2" y1="15" x2="4" y2="15"/><line x1="20" y1="9" x2="22" y2="9"/><line x1="20" y1="15" x2="22" y2="15"/>`,
    code: `# Mesh with NVIDIA GPU inference
docker compose -f recipes/mesh-gpu.yml up -d`,
  },
  {
    id: "helm",
    label: "Helm",
    icon: `<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><line x1="2" y1="12" x2="22" y2="12"/>`,
    code: `cd deploy/helm/astromesh
helm dependency update
helm install astromesh . -f values-dev.yaml \\
  --namespace astromesh --create-namespace
kubectl get pods -n astromesh`,
  },
  {
    id: "argocd",
    label: "ArgoCD",
    icon: `<circle cx="12" cy="12" r="4"/><line x1="1.05" y1="12" x2="7" y2="12"/><line x1="17.01" y1="12" x2="22.96" y2="12"/>`,
    code: `# Multi-environment GitOps deployment
kubectl apply -f deploy/gitops/argocd/applicationset.yaml
# Creates: astromesh-dev, astromesh-staging, astromesh-prod`,
  },
];
---

<div class="deploy-tabs">
  <div class="tab-bar" role="tablist" aria-label="Deployment modes">
    {tabs.map((tab, i) => (
      <button
        role="tab"
        id={`tab-${tab.id}`}
        aria-selected={i === 0 ? "true" : "false"}
        aria-controls={`panel-${tab.id}`}
        class:list={["tab-btn", { active: i === 0 }]}
        data-tab={tab.id}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <Fragment set:html={tab.icon} />
        </svg>
        <span>{tab.label}</span>
      </button>
    ))}
  </div>

  {tabs.map((tab, i) => (
    <div
      role="tabpanel"
      id={`panel-${tab.id}`}
      aria-labelledby={`tab-${tab.id}`}
      class="tab-panel"
      style={i === 0 ? "display: block;" : "display: none;"}
    >
      <div class="code-wrap">
        <button class="cp-btn" data-code={tab.code} aria-label="Copy code">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
          </svg>
          <span>Copy</span>
        </button>
        <pre><code>{tab.code}</code></pre>
      </div>
    </div>
  ))}
</div>

<script>
  function initDeployTabs() {
    const c = document.querySelector(".deploy-tabs");
    if (!c) return;

    c.querySelectorAll<HTMLButtonElement>("[role='tab']").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.dataset.tab;
        c.querySelectorAll<HTMLButtonElement>("[role='tab']").forEach((b) => {
          b.classList.remove("active");
          b.setAttribute("aria-selected", "false");
        });
        btn.classList.add("active");
        btn.setAttribute("aria-selected", "true");
        c.querySelectorAll<HTMLDivElement>("[role='tabpanel']").forEach((p) => {
          p.style.display = p.id === `panel-${id}` ? "block" : "none";
        });
      });
    });

    c.querySelectorAll<HTMLButtonElement>(".cp-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        navigator.clipboard.writeText(btn.dataset.code ?? "").then(() => {
          const label = btn.querySelector("span");
          if (label) { label.textContent = "Copied!"; setTimeout(() => { label.textContent = "Copy"; }, 2000); }
        });
      });
    });
  }

  document.addEventListener("astro:page-load", initDeployTabs);
  initDeployTabs();
</script>

<style>
  .deploy-tabs {
    border-radius: var(--am-radius, 0.625rem);
    border: 1px solid var(--am-border, rgba(255,255,255,0.08));
    overflow: hidden;
    margin: 1.5rem 0;
    background: var(--am-surface, rgba(255,255,255,0.02));
  }

  .tab-bar {
    display: flex;
    overflow-x: auto;
    border-bottom: 1px solid var(--am-border, rgba(255,255,255,0.08));
    background: rgba(0,0,0,0.15);
    scrollbar-width: thin;
    gap: 0;
  }

  .tab-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
    padding: 0.65rem 1rem;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    color: var(--sl-color-gray-3);
    font-size: 0.8rem;
    font-weight: 500;
    font-family: var(--sl-font, sans-serif);
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .tab-btn:hover {
    color: var(--sl-color-text);
    background: rgba(255,255,255,0.03);
  }

  .tab-btn.active {
    color: var(--sl-color-accent);
    border-bottom-color: var(--sl-color-accent);
    background: rgba(0,212,255,0.05);
  }

  .tab-btn svg {
    opacity: 0.6;
  }

  .tab-btn.active svg {
    opacity: 1;
  }

  .code-wrap {
    position: relative;
  }

  .cp-btn {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.6rem;
    background: rgba(0,0,0,0.3);
    border: 1px solid var(--am-border, rgba(255,255,255,0.1));
    border-radius: 0.35rem;
    color: var(--sl-color-gray-3);
    font-size: 0.7rem;
    font-family: var(--sl-font, sans-serif);
    cursor: pointer;
    z-index: 2;
    transition: color 0.2s, border-color 0.2s;
  }

  .cp-btn:hover {
    color: var(--sl-color-accent);
    border-color: var(--sl-color-accent);
  }

  pre {
    margin: 0;
    padding: 1.25rem;
    background: transparent;
    overflow-x: auto;
    font-size: 0.82rem;
    line-height: 1.7;
  }

  code {
    font-family: var(--sl-font-mono, monospace);
    color: var(--sl-color-text);
  }
</style>
