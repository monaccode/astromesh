{% for svc in services %}
resource "google_cloud_run_v2_service" "{{ svc.key }}" {
  name     = "{{ svc.name }}"
  location = var.region
  project  = var.project_id

  template {
    service_account = google_service_account.orbit.email

    scaling {
      min_instance_count = {{ svc.spec.min_instances }}
      max_instance_count = {{ svc.spec.max_instances }}
    }

    vpc_access {
      connector = google_vpc_access_connector.orbit.id
      egress    = "PRIVATE_RANGES_ONLY"
    }

    containers {
      image = "{{ svc.image }}"
{% if observability.tracing.enabled %}
      name       = "runtime"
      depends_on = ["otel-collector"]
{% endif %}

      ports {
        container_port = 8000
      }

      resources {
        limits = {
          cpu    = "{{ svc.spec.cpu }}"
          memory = "{{ svc.spec.memory }}"
        }
      }

      env {
        name  = "ASTROMESH_DATABASE_URL"
        value = "postgresql+asyncpg://astromesh:${random_password.db_password.result}@/astromesh?host=/cloudsql/${google_sql_database_instance.main.connection_name}"
      }
      env {
        name  = "ASTROMESH_REDIS_URL"
        value = "redis://${google_redis_instance.main.host}:${google_redis_instance.main.port}"
      }
{% if storage.rag_documents.enabled %}
      env {
        name  = "ASTROMESH_RAG_BUCKET"
        value = google_storage_bucket.rag_documents.name
      }
{% endif %}
{% if observability.tracing.enabled %}
      env {
        name  = "ASTROMESH_OTLP_ENABLED"
        value = "1"
      }
      env {
        name  = "OTEL_EXPORTER_OTLP_ENDPOINT"
        value = "http://localhost:4317"
      }
{% endif %}
{% for key, value in custom_env.items() %}
      env {
        name  = "{{ key }}"
        value = "{{ value }}"
      }
{% endfor %}

      volume_mounts {
        name       = "cloudsql"
        mount_path = "/cloudsql"
      }
    }
{% if observability.tracing.enabled %}
    containers {
      name  = "otel-collector"
      image = "{{ observability.tracing.collector_image }}"
      args  = ["--config=env:OTEL_COLLECTOR_CONFIG"]

      env {
        name  = "OTEL_COLLECTOR_CONFIG"
        value = <<-EOT
          receivers:
            otlp:
              protocols:
                grpc:
                  endpoint: 0.0.0.0:4317
          exporters:
            googlecloud:
              project: ${var.project_id}
          service:
            pipelines:
              traces:
                receivers: [otlp]
                exporters: [googlecloud]
        EOT
      }

      resources {
        limits = {
          cpu    = "1"
          memory = "512Mi"
        }
      }
    }
{% endif %}

    volumes {
      name = "cloudsql"
      cloud_sql_instance {
        instances = [google_sql_database_instance.main.connection_name]
      }
    }
  }
}

{% endfor %}
