FROM nvidia/cuda:12.1.0-runtime-ubuntu22.04

RUN apt-get update && apt-get install -y python3.12 python3-pip && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN pip install uv

COPY pyproject.toml uv.lock* ./
COPY README.md ./
RUN uv sync --extras ml --extras onnx --no-dev

COPY astromesh/ astromesh/
COPY config/ config/

EXPOSE 8000

CMD ["uv", "run", "uvicorn", "astromesh.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
